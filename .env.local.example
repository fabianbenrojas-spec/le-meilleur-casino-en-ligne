# ─────────────────────────────────────────────────────────────────
# le-meilleur-casino-en-ligne.fr — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs.
# Sur Vercel : ajouter via Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.le-meilleur-casino-en-ligne.fr

# ── Google Tag Manager ────────────────────────────────────────────
# Remplacer GTM-XXXXXXX par votre container ID réel
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ── Email — Contact form (Resend) ─────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Adresse de réception des messages de contact
CONTACT_EMAIL=contact@le-meilleur-casino-en-ligne.fr

# ── Newsletter (Mailchimp) ────────────────────────────────────────
# API key : Mailchimp → Account → Extras → API keys
MAILCHIMP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us1
# List/Audience ID : Mailchimp → Audience → Settings → Audience name & defaults
MAILCHIMP_LIST_ID=xxxxxxxxxx
# Data center prefix (visible dans l'URL Mailchimp : usX ou euX)
MAILCHIMP_DC=us1
