								<p class="font-weight-bold text-success h5">After the first payment:</p>
								
								<ul>
								
									<li class="text-secondary">Use the domain immediately</li>
									<li class="text-secondary">Full ownership after <span class="period font-weight-bold">24</span> months</li>
									<li class="text-secondary">Stop at any time</li>
								
								</ul>
								
								<div class="form-check">
									<input class="form-check-input" type="checkbox" value="1" id="dan_terms" required>
									<label class="form-check-label text-secondary" for="dan_terms">
										I accept the Dan.com <a target="_blank" href="https://dan.com/legal/terms-of-use"><u>terms of use</u></a>
									</label>
								</div>
								
							</div>
						
						</div>
						
						<div class="row mt-4 text-start">
						
							<div class="col-12">
							
								<button class="btn btn-lg w-100 btn-success" id="process_installments" type="submit">Start first payment</button>
							
							</div>
						
						</div>
				
					</div>
				
				</form>
		
			</div>

		</div>

    <script>

    $( document ).ready(function() {

        // Post the installment data to the DAN.com API, when submitted
        $( '#process_installments').click(function( e ) {

            e.preventDefault();

            // Show spinner
            $('div#preloader').show();
            $('div#preloader').fadeTo( 0, 0.8);
            $('div#preloader #status').show();

            // Get nr of months
            var month_selector = $('#month_selector');
            var nr_of_months = $(month_selector).val();

            // Get status of terms checkbox
            var terms_selector = $('#dan_terms');
            var terms_accepted = false;
            if (terms_selector.is(':checked')) {
                terms_accepted = 1;
            }

            // Post to file that handles validation and the initiation of the transaction
            Odf.ajax.post('ajaxa/transactions/initiate_dan/', 'div#response_dan_installments_', { domain_id: '2l705', user_id: 'u3', nr_of_installments: nr_of_months, terms_accepted: terms_accepted });
            return true;

        });

        // Function to update the pricing, nr of installments etc when the nr of installments is changed by the user
        function updatePricing() {

            // Format currency as $ 1,234,5678
            const formatter = new Intl.NumberFormat('en-US', {
                style: 'currency',
                currency: 'USD',
                minimumFractionDigits: 0
            })

            // Get nr of months
            var month_selector = $('#month_selector');
            var nr_of_months = $(month_selector).val();

            // Calculate new price
            var bin_price = 45000.00;

            // Calculate long term markup
            var markup = 0;

            // Markup is based on nr of months selected by user
            if (nr_of_months <= 12)
                markup = 0;
            else if (nr_of_months > 12 && nr_of_months <= 24)
                markup = 0.1;
            else if (nr_of_months > 24 && nr_of_months <= 36)
                markup = 0.2;
            else if (nr_of_months => 36)
                markup = 0.3;
            else
                markup = 0;

            // Calculate and round the final price per month and total price
            var total_price = bin_price * (1 + markup);
            var price = Math.ceil(total_price / nr_of_months);
            var total_price = Math.ceil(total_price);

            // Update accordingly
            $('.period').text(nr_of_months);
            $('.price').text(formatter.format(price));
            $('.markup').text(markup * 100);
            $('.price_total').text(formatter.format(total_price));

        }

        // Update pricing upon # of installments change
        $( '#month_selector').change(function() {

            updatePricing( );

        });

        // Initial update of all pricing data
        updatePricing( );

    });

    </script>				
			</section>
			<!-- /DAN Installments -->
						
			
		
					
								
