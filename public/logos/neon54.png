        --srw-onboarding_slide03_big-wins-img__height: auto;
        --srw-onboarding_slide03_big-wins-img__width: 221px;

        --srw-onboarding_slide03_normal-wins-img__height: auto;
        --srw-onboarding_slide03_normal-wins-img__width: 221px;

