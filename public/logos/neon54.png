        --srw-title-desktop--medium__font-size: 16px;
        --srw-title-desktop--medium__line-height: 20px;
        --srw-title__color: var(--stb-text-neutral-200);

        --srw-button--link-secondary__color: var(--stb-main-brand-l200);
        --srw-button--link-secondary-hover__color: var(--stb-text-neutral-400);
        --srw-button--link-secondary-active__color: var(--stb-main-accent-contrast);

        --srw-tournament-points-rules-plate__border: 1px solid var(--stb-tint-neutral-100);
        --srw-tournament-points-rules-plate_description__gap: 2px;
        --srw-tournament-points-rules-plate_name__color: var(--stb-text-neutral-100);
        --srw-tournament-points-rules-plate_name__font-size: 12px;
        --srw-tournament-points-rules-plate_name__font-weight: 400;
        --srw-tournament-points-rules-plate_name__line-height: 18px;
        --srw-tournament-points-rules-plate_points__color: var(--stb-text-neutral-300);
        --srw-tournament-points-rules-plate_points__font-size: 12px;
        --srw-tournament-points-rules-plate_points__font-weight: 700;
        --srw-tournament-points-rules-plate_points__line-height: 18px;

        --srw-button--link-mob__font-size: 14px;
        --srw-button--link__letter-spacing: -0.25px;
        --srw-button--link__line-height: 20px;
        --srw-button--link-desk__font-size: 14px;
        --srw-button--link-primary__color: var(--stb-text-neutral-200);
        --srw-button--link-primary-hover__color: var(--stb-text-neutral-250);
        --srw-button--link-primary-active__color: var(--stb-text-neutral-150);

