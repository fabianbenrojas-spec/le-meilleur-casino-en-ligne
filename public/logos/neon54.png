    <style>
      .preloader {
        position: fixed;
        overflow: hidden;
        inset: 0;
        z-index: 10;
        background-color: rgb(57 49 47);
      }
      .preloader__container {
        position: relative;
        width: 100%;
        height: 100%;
        display: grid;
        grid-template: auto / auto;
        align-items: center;
        justify-items: center;
      }
      .preloader__bg {
        position: relative;
        grid-area: 1 / 1 / -1 / -1;
        width: 100%;
        height: 100%;
        display: grid;
        overflow: hidden;
      }
      .preloader__bg--top {
        grid-area: 1 / 1 / -1 / -1;
        object-fit: cover;
        width: 100%;
        height: 100%;
      }
      .preloader__bg--main {
        grid-area: 1 / 1 / -1 / -1;
        object-fit: cover;
        width: 100%;
        height: 100%;
      }
      .preloader__logo {
        z-index: 1;
        grid-area: 1 / 1 / -1 / -1;
        padding: 64px;
      }
    </style>
    <style id="spin-rally-styles">
      :host {
        /* Font family */
        --srw-body-font-family: var(--stb-font-family-body-strong-md);
        --srw-headline-font-family: var(--stb-font-family-headline-md);
        --srw-button-font-family: var(--stb-font-family-button-md);

        /* Font sizes */
        --srw-header_title--mob__font-size: var(--srw-headline-xs-font-size);
        --srw-header_title--desk__font-size: var(--srw-headline-md-font-size);
        --srw-dropdown-player-points_name__font-size: var(--srw-body-xxs-font-size);
        --srw-statistics-plate_title__font-size: var(--srw-font-size-150);
        --srw-sr-notification-countdown-compact__font-size: var(--srw-font-size-150);
        --srw-bar_statistics-label-desktop__font-size: var(--srw-font-size-150);

        /* Line heights */
        --srw-terms-conditions_content__font-weight: var(--srw-body-font-weight);
        --srw-bar_countdown-label__font-weight: var(--stb-font-weight-body-md);

        /* Font styles */
        --srw-text-font-style: var(--stb-font-style-display-md);

        /* Paddings */
        --srw-bar_countdown-label__font-weight: 8px;

        /* Margins */
        --srw-bar_countdown__margin-inline-end: 4px;

        /* Color */
        --srw-tournament_card-container__outline: solid 1px var(--stb-tint-neutral-100);
        --srw-tournament-details__background-color: var(--stb-base);
        --srw-table_header__color: var(--stb-text-neutral-300);
        --srw-leaderboard-and-prizes_prize__color: var(--stb-text-accent-l200);
        --srw-points-rules_group-title--normal__color: var(--stb-text-warning-base);
        --srw-points-rules_group-description__color: var(--stb-text-neutral-200);
        --srw-onboarding-bullets_bullet__background-color: color-mix(
          in srgb,
          var(--stb-text-neutral-250),
          transparent var(--srw-onboarding-bullets_bullet__opacity)
        );
        --srw-onboarding_slide__color: var(--stb-text-neutral-100);
        --srw-bar-desktop__color: var(--stb-text-neutral-200);
        --srw-switch--checked_track__background-color: var(--stb-main-accent-base);
        --srw-bar-desktop--medium__background-color: var(--stb-tint-neutral-100);
        --srw-bar_statistics__color: var(--stb-text-neutral-200);
        --srw-bar_countdown__color: var(--stb-tint-neutral-50);
        --stb-custom-srw-widget-desktop-container-background: rgb(9 8 12 / 1);
        --srw-slider-banner_tournament__border-color: var(--stb-tint-neutral-150);
        --srw-slider-banner_tournament__background-color: var(--stb-tint-neutral-50);
        --srw-slider-banner_tournament-active-timer__color: var(--stb-main-brand-contrast);
        --srw-slider-banner__spacing: 16px 16px 0;
        --srw-tournament_category--next__background-color: var(--srw-light-main-accent-base);
        --srw-tournament_category--next__color: var(--stb-main-brand-contrast);
        --srw-tournament_category--active__color: var(--stb-main-brand-contrast);
        --srw-tournament_category--active__background-color: var(--srw-light-main-brand-contrast);
        --srw-sr-notification-body__color: var(--stb-text-warning-base);
        --srw-sr-notification-cta-text__color: var(--stb-text-neutral-200);
        --srw-bar_close-btn__color: var(--stb-text-neutral-250);
        --srw-bar_place__icon-color: var(--stb-text-neutral-400);
        --srw-bar_body__border-color: var(--stb-main-neutral-d200);
        --srw-bar_toggle-button-icon__color: var(--stb-text-neutral-200);
        --srw-bar_prefix-icon__color: var(--stb-text-neutral-300);
        --srw-bar_prefix-icon-wrapper__border-color: var(--stb-main-neutral-d200);
        --srw-dropdown-player-points_total-points_value__color: var(--stb-text-neutral-200);
        --srw-panel-expanded__background-color: var(--stb-base);
        --srw-dropdown-player-points_points__color: var(--stb-text-neutral-300);

        --srw-dropdown-player-points_plate__border-color: var(--stb-tint-neutral-100);
        --srw-dropdown-player-points_plate__background-color: var(--stb-base);
        --srw-statistics-plate__border-color: var(--stb-tint-neutral-100);
        --srw-bar_place--is-plate__icon-color: var(--stb-text-neutral-300);
        --srw-bar_place--is-plate__color: var(--stb-text-neutral-200);
        --srw-bar_spins_value__color: var(--stb-text-neutral-200);
        --srw-bar_spins__color: var(--stb-text-neutral-300);
        --srw-bar--medium__background-color: var(--stb-tint-neutral-100);
        --srw-bar-dropdown__border-color: var(--stb-tint-neutral-100);
        --srw-switch--checked_track__background-color: var(--stb-main-brand-l100);
        --srw-settings-item_description__color: var(--stb-text-neutral-200);
        --srw-bar__color: var(--stb-text-neutral-200);
        --srw-panel-expanded_header__background-color: var(--stb-base);
        --srw-bar-dropdown__background-color: var(--stb-base);
        --srw-bar-dropdown_header__background-color: var(--stb-base);
        --srw-table_row--highlighted__color: var(--stb-main-brand-contrast);
        --srw-leaderboard-and-prizes_prize--highlighted__color: var(--stb-text-accent-l200);
        --srw-button--link-seeall__color: var(--stb-text-accent-base);
        --srw-slider-banner_arrow-button__background: var(--stb-base);
        --srw-slider-banner_arrow-button--disabled__background: var(--stb-base);
        --srw-slider-banner_arrow-button--active__background: var(--stb-base);
        --srw-slider-banner_arrow-button--hover__background: var(--stb-base);
        --srw-slider-banner_arrow-button--disabled__color: var(--stb-tint-accent-150);
        --srw-slider-banner_arrow-button__color: var(--stb-text-accent-base);
        --srw-slider-banner_arrow-button--hover__color: var(--stb-text-accent-l200);
        --srw-slider-banner_arrow-button--active__color: var(--stb-text-accent-d200);
        --srw-leaderboard-and-prizes_place--highlighted_current-player__color: var(
          --stb-main-brand-contrast
        );
        --srw-leaderboard-and-prizes_place--highlighted_current-player__background-color: none;
        --srw-button--link-seeall-hover__color: var(--stb-text-accent-l200);
        --srw-sr-notification-timer-body__color: var(--stb-tint-neutral-50);
        --srw-dialog-outcome-card-statistics__color: var(--stb-text-neutral-200);
        --srw-dialog_outcome-card-statistics__background-color: var(--stb-tint-neutral-100);
        --stb-modal-dialog-separator-text-color: var(--stb-text-neutral-400);
        --srw-sr-notification-timer-flag__color: var(--stb-tint-neutral-500);

        /* Gap */

        --srw-sr-notification-timer-body__gap: 2px;

        /* Text decoration */
        --srw-button--link-secondary__text-decoration: underline;

        /* Boder radius */
        --srw-onboarding-bullets_bullet__border-radius: 50px;

        /* Widht */
        --srw-bar_place_branch__width: 8px;
        --srw-slider-banner_arrow-button__width: 16px;

        /* Height */
        --srw-bar_place_branch__height: 18px;

        /* Inset */

        --srw-bar-dropdown__inset-inline-end: 4px;

        /**/
        /* Base */
        --srw-light-text-brand-base: var(--stb-text-brand-base);
        --srw-light-base: var(--stb-base);
        --srw-light-text-brand-l200: var(--stb-main-brand-l200);
        --srw-light-text-brand-d200: var(--stb-main-brand-base);
        --srw-light-text-neutral-300: var(--stb-text-neutral-200);
        --srw-light-tint-neutral-150: var(--stb-tint-neutral-150);
        --srw-light-text-neutral-200: var(--stb-text-neutral-250);
        --srw-light-main-brand-l100: var(--stb-main-brand-base);
        --srw-light-main-brand-contrast: var(--stb-main-accent-base);
        --srw-light-tint-neutral-50: var(--stb-tint-neutral-25);
        --srw-light-main-accent-base: var(--stb-main-brand-l100);
        --srw-light-main-brand-l200: var(--stb-text-neutral-200);
        --srw-light-main-brand-base: var(--stb-tint-neutral-100);
        --srw-light-tint-brand-50: var(--stb-layout-background-color);

        --srw-slider-banner_title__color: var(--stb-page-header-title-text-color);
        --srw-bar_statistics-vertical__gap: 16px;

        --srw-desktop-panel_ufc-header__height: calc(
          var(--stb-game-page-header-height) +
            var(--stb-custom-widget-desktop-container-padding-block, 0px) * 2
        );

        --srw-text-color-primary: var(--stb-text-neutral-200);
        --srw-text-color-secondary: var(--stb-text-neutral-300);
        --srw-brand-color-500: var(--stb-text-brand-base);

        --srw-background-color-secondary: var(--stb-tint-neutral-50);

        --srw-icon-color-400: var(--stb-text-neutral-300);

        --srw-header_title__color: var(--stb-text-neutral-200);
        --srw-header_icon__color: var(--stb-text-neutral-250);
        --srw-header_title--mob__line-height: 24px;
        --srw-header_title--desk__line-height: 32px;
        --srw-header_title--mob__font-family: var(--stb-font-family-headline-xs);
        --srw-header_title--desk__font-family: var(--stb-font-family-headline-md);

        --srw-hero-banner__background-color: var(--stb-tint-brand-50);
        --srw-hero-banner_secondary-text__line-height: 22px;
        --srw-hero-banner_secondary-text__color: var(--stb-text-accent-l200);
        --srw-hero-banner_primary-text__line-height: 24px;
        --srw-hero-banner_primary-text__color: var(--stb-text-neutral-200);

        --srw-tab__color: var(--stb-text-neutral-500);
        --srw-tab__background-color: var(--stb-text-neutral-200);
        --srw-tab__padding: 6px 8px;
        --srw-tab__font-weight: 700;
        --srw-tab__line-height: 20px;
        --srw-tab--active__color: var(--stb-text-neutral-100);
        --srw-tab--active__background-color: var(--stb-main-brand-base);

        --srw-tournament_active__background-color: var(--stb-tint-neutral-25);
        --srw-tournament_next__background-color: var(--stb-tint-neutral-25);
        --srw-tournament_default__background-color: var(--stb-tint-neutral-25);

        --srw-tournaments-list-group_name__color: var(--stb-main-brand-contrast);
        --srw-tournaments-list-group_name__background-color: var(--stb-main-info-d200);
        --srw-tournaments-list-group_name__line-height: 20px;
        --srw-tournaments-list-group--next_name__background-color: var(--stb-main-brand-l100);
        --srw-tournaments-list-group--active_name__background-color: var(--stb-main-accent-base);

        --srw-tournaments-list-group_marker__border-color: var(--stb-main-info-d200);
        --srw-tournaments-list-group--next_marker__border-color: var(--stb-main-brand-l100);
        --srw-tournaments-list-group--active_marker__border-color: var(--stb-main-accent-base);
        --srw-tournaments-list_vertical-line__border-color: var(--stb-tint-neutral-100);

        --srw-tournament_name__color: var(--stb-text-neutral-150);
        --srw-tournament_name__line-height: 20px;
        --srw-tournament_name--desktop__line-height: 22px;

        --srw-tournament_details-line-name__line-height: 16px;
        --srw-tournament_details-line-name__color: var(--stb-text-neutral-150);
        --srw-tournament_details-line-value__color: var(--stb-text-neutral-150);

        --srw-tournament_active-timer__color: var(--stb-main-brand-contrast);
        --srw-tournament_active-timer__font-size: 10px;
        --srw-tournament_active-timer__line-height: 16px;
        --srw-tournament_active-timer__background-color: var(--stb-text-brand-base);

        --srw-tournament-details_summary__color: var(--stb-text-neutral-100);
        --srw-tournament-details_summary__background-color: var(--stb-tint-neutral-100);
        --srw-tournament-details_summary__padding-block: 9px;
        --srw-tournament-details_summary__line-height: 18px;
        --srw-tournament-details_summary__font-weight: 700;
        --srw-tournament-details_summary--hover__color: var(--stb-text-neutral-100);
        --srw-tournament-details_summary--hover__background-color: var(--stb-tint-neutral-150);

        --srw-table__background-color: var(--stb-tint-neutral-50);
        --srw-table__color: var(--stb-text-neutral-200);
        --srw-table_caption__color: var(--stb-text-neutral-200);
        --srw-table_row--odd__background-color: var(--stb-tint-neutral-100);
        --srw-leaderboard-and-prizes_place--highlighted__color: var(--stb-main-brand-contrast);
        --srw-leaderboard-and-prizes_place--highlighted__background-color: var(
          --stb-main-brand-base
        );

        --srw-tournament-rules-plate__background-color: var(--stb-tint-neutral-25);
        --srw-tournament-rules-plate__border: 1px solid var(--stb-tint-neutral-100);
        --srw-tournament-rules-plate_title__color: var(--stb-text-neutral-100);
        --srw-tournament-rules-plate_title__font-weight: 400;
        --srw-tournament-rules-plate_title__line-height: 16px;
        --srw-tournament-rules-plate_value__color: var(--stb-text-neutral-300);
        --srw-tournament-rules-plate_value__font-weight: 700;
        --srw-tournament-rules-plate_value__line-height: 18px;

        --srw-title-mobile--medium__font-size: 16px;
